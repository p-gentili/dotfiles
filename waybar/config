{
    "layer": "top",
    "height": 30,
    "spacing": 4,
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "custom/theme",
        "cpu",
        "memory",
        "temperature",
        "backlight",
        "pulseaudio",
        "battery",
        "tray"
    ],
    "clock": {
        "format": "{:%A %d %B - %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col": 2,
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#fffffe'><b>{}</b></span>",
                              "days":       "<span color='#efefef'><b>{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff0000'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "cpu": {
        "format": "CPU {usage}%",
        "tooltip": false,
        "on-click": "kitty --override background=#000000 htop"
    },
    "memory": {
        "format": "RAM {}%"
    },
    "battery": {
		"on-click": "~/.local/bin/power-menu",
		"states": {
			 "warning": 25,
			 "critical": 10
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["", "", "", "", ""]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["", "", "", "", ""],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-"
    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-muted": "",
        "format-icons": { "default": ["", "", ""] },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },
    "tray": {
        "icon-size": 18,
        "spacing": 10
    },
    "custom/theme": {
        "format": "{}",
        "exec": "~/.local/bin/theme-status",
        "interval": 2,
        "on-click": "~/.local/bin/theme-toggle",
        "tooltip": false
    }
}
