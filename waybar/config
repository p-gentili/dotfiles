{
    "layer": "top",
    "height": 30,
    "spacing": 4,
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "temperature",
        "network",
        "battery"
    ],
    "clock": {
        "format": "{:%A %d %B - %H:%M}",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
                    "mode"          : "month",
                    "mode-mon-col": 2,
                    "on-scroll"     : 1,
                    "format": {
                              "months":     "<span color='#fffffe'><b>{}</b></span>",
                              "days":       "<span color='#efefef'><b>{}</b></span>",
                              "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                              "today":      "<span color='#ff0000'><b><u>{}</u></b></span>"
                              }
                    },
        "actions":  {
                    "on-click-right": "mode",
                    "on-scroll-up": "shift_up",
                    "on-scroll-down": "shift_down"
                    }
    },
    "cpu": {
        "format": "CPU {usage}%",
        "tooltip": false,
        "on-click": "kitty --override background=#000000 htop"
    },
    "memory": {
        "format": "RAM {}%"
    },
    "network": {
        "format-wifi": "{essid} ({signalStrength}%) ",
        "format-ethernet": "{ifname} "
    },
    "battery": {
		"states": {
			 "warning": 25,
			 "critical": 10
		},
		"format": "{capacity}% {icon}",
		"format-icons": ["", "", "", "", ""]
    }
}
