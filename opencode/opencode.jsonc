{
  "$schema": "https://opencode.ai/config.json",
  "theme": "system",
  "mcp": {
    "logseq": {
      "type": "local",
      "command": ["uvx", "mcp-logseq"],
      "env": {
        "LOGSEQ_API_TOKEN": "${LOGSEQ_API_TOKEN}",
        "LOGSEQ_API_URL": "http://localhost:12315"
      },
      "enabled": false
    },
    "kicad": {
      "type": "local",
      "command": [
        "node",
        "/home/paolo.gentili@canonical.com/MCP/KiCAD-MCP-Server/dist/index.js"
      ],
      "environment": {
        "NODE_ENV": "production",
        "LOG_LEVEL": "info",
        "KICAD_AUTO_LAUNCH": "false",
        "KICAD_MCP_DEV": "0",
        "KICAD_BACKEND": "auto",
        "PYTHONPATH": "/usr/lib/python3/dist-packages"
      },
      "enabled": false,
      "timeout": 30000
    }
  }
}
