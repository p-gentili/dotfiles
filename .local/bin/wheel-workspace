#!/usr/bin/env python3
"""Map the MX Ergo trackball's horizontal wheel tilt to sway workspace switching.

Why this exists: sway's `bindsym button6/button7` is global and can't be scoped
to one device, so binding horizontal scroll there also fires on the touchpad's
two-finger drift. Reading evdev directly lets us watch ONLY the trackball, leaving
the touchpad free (it uses `bindgesture swipe:3` instead).

Requires read access to /dev/input/event*, i.e. membership in the `input` group:
    sudo usermod -aG input "$USER"   # then log out / back in

Launched from sway via `exec wheel-workspace`.
"""
import subprocess
import time

import evdev
from evdev import ecodes

DEVICE_MATCH = "MX Ergo"        # substring of the device name to watch
TILT_RIGHT_ACTION = ["workspace", "next"]
TILT_LEFT_ACTION = ["workspace", "prev"]


def find_device():
    """Return the first input device whose name matches and reports REL_HWHEEL."""
    for path in evdev.list_devices():
        try:
            dev = evdev.InputDevice(path)
        except (OSError, PermissionError):
            continue
        rel = dev.capabilities().get(ecodes.EV_REL, [])
        if DEVICE_MATCH in dev.name and ecodes.REL_HWHEEL in rel:
            return dev
    return None


def switch(direction):
    action = TILT_RIGHT_ACTION if direction > 0 else TILT_LEFT_ACTION
    subprocess.run(["swaymsg", *action], check=False)


def watch(dev):
    print(f"wheel-workspace: watching {dev.name} ({dev.path})", flush=True)
    for event in dev.read_loop():
        # REL_HWHEEL fires once per detent: +1 tilt right, -1 tilt left.
        # (Ignore REL_HWHEEL_HI_RES to avoid multiple triggers per detent.)
        if event.type == ecodes.EV_REL and event.code == ecodes.REL_HWHEEL:
            if event.value != 0:
                switch(event.value)


def main():
    while True:
        dev = find_device()
        if dev is None:
            time.sleep(3)  # trackball may be asleep / disconnected (Bluetooth)
            continue
        try:
            watch(dev)
        except OSError:
            # Device went away (disconnect); fall through and re-discover.
            time.sleep(1)


if __name__ == "__main__":
    main()
