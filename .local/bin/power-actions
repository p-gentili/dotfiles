#!/usr/bin/env bash
# Session power actions via a wofi menu: shutdown, reboot, suspend.
set -euo pipefail

choice=$(printf '%s\n' "  Shutdown" "  Reboot" "  Suspend" \
    | wofi --dmenu --prompt "Power" \
           --width 200 --height 160 \
           --location top_right --xoffset -10 --yoffset 40 \
           --style ~/.config/wofi/style.css)

case "${choice:-}" in
  *Shutdown) systemctl poweroff ;;
  *Reboot)   systemctl reboot ;;
  *Suspend)  systemctl suspend ;;
esac
